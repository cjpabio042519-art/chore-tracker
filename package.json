{
  "name": "chore-master",
  "version": "1.0.0",
  "description": "Chore Tracker with MVC, JWT, and JSON Server",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "server": "nodemon backend/server.js",
    "json-server": "json-server --watch db.json --port 3001",
    "dev": "concurrently \"npm run json-server\" \"npm run server\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "json-server": "^0.17.4"
  }
}
